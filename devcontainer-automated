#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_NAME="$(basename "$0")"
WORKSPACE_DIR="$(pwd -P)"
CONTAINER_DIR="/workspaces/${WORKSPACE_DIR##*/}"
WORKSPACE_KEY="$(printf '%s' "${WORKSPACE_DIR}" | od -An -tx1 | tr -d ' \n')"
FOLDER_URI="vscode-remote://dev-container+${WORKSPACE_KEY}${CONTAINER_DIR}"
CONTAINER_LABEL="devcontainer.local_folder=${WORKSPACE_DIR}"
HASH_FILE="${TMPDIR:-/tmp}/devcontainer-init/${WORKSPACE_KEY}.hash"
PROXY_SOCKET="/tmp/1password-ssh-agent.sock"
VAULT=""
SERVICE_ACCOUNT_TOKEN=""
CONTAINER_USER="vscode"
CONTAINER_SHELL="bash"
LOG_LEVEL=info

log() {
    local level=info levels=" debug info warn error "

    case "${1:-}" in info | error | debug | warn) level="$1"; shift ;; esac
    [[ "${levels}" == *" ${LOG_LEVEL} "* ]] || LOG_LEVEL=info
    [[ "${level}" == debug && "${LOG_LEVEL}" != debug ]] && return 0
    printf '[%s] %s\n' "${level}" "$*" >&2
}

usage() {
    cat <<EOF
Usage: ${SCRIPT_NAME} [options] [command]

Commands:
  rebuild  Force rebuild a devcontainer
  code     Open VS Code in the devcontainer
  shell    Open a shell in the running devcontainer

Options:
  --vault <vault>         1Password vault containing OP_SERVICE_ACCOUNT_TOKEN
  --token <token>         Use a service account token directly
  --user <user>           Container user for the interactive shell (default: vscode)
  --shell <shell>         Container shell command for the interactive shell (default: bash)
  --workspace <path>      Use a workspace path instead of the current directory
  --debug                 Enable debug logs
EOF
}

set_workspace() {
    local requested_dir="${1}"

    [[ -d "${requested_dir}" ]] || {
        log error "Workspace directory not found: ${requested_dir}"
        exit 1
    }

    WORKSPACE_DIR="$(cd "${requested_dir}" && pwd -P)"
    CONTAINER_DIR="/workspaces/${WORKSPACE_DIR##*/}"
    WORKSPACE_KEY="$(printf '%s' "${WORKSPACE_DIR}" | od -An -tx1 | tr -d ' \n')"
    FOLDER_URI="vscode-remote://dev-container+${WORKSPACE_KEY}${CONTAINER_DIR}"
    CONTAINER_LABEL="devcontainer.local_folder=${WORKSPACE_DIR}"
    HASH_FILE="${TMPDIR:-/tmp}/devcontainer-init/${WORKSPACE_KEY}.hash"
}

require_workspace_config() {
    [[ -d "${WORKSPACE_DIR}/.devcontainer" ]] || {
        log error "No .devcontainer directory found in ${WORKSPACE_DIR}"
        exit 1
    }
}

use_colima() {
    unset DOCKER_CONTEXT
    export DOCKER_HOST="ssh://colima"
    log debug "Using Colima via DOCKER_HOST=${DOCKER_HOST}"
}

start_proxy() {
    log "Starting 1Password SSH agent proxy"

    if ssh -S none colima \
        "test -S '${PROXY_SOCKET}' && SSH_AUTH_SOCK='${PROXY_SOCKET}' ssh-add -L >/dev/null 2>&1" \
        >/dev/null 2>&1; then
        log debug "Reusing existing SSH agent proxy at ${PROXY_SOCKET}"
        return 0
    fi

    log debug "Creating SSH agent proxy at ${PROXY_SOCKET}"
    ssh -S none -A -f colima \
        "rm -f '${PROXY_SOCKET}'; \
         exec socat UNIX-LISTEN:${PROXY_SOCKET},fork,unlink-early,mode=660 UNIX-CONNECT:\"\$SSH_AUTH_SOCK\"" \
        >/dev/null 2>&1

    for _ in {1..20}; do
        if ssh -S none colima \
            "test -S '${PROXY_SOCKET}' && SSH_AUTH_SOCK='${PROXY_SOCKET}' ssh-add -L >/dev/null 2>&1" \
            >/dev/null 2>&1; then
            return 0
        fi
        sleep 0.2
    done

    log error "SSH agent proxy socket was not created: ${PROXY_SOCKET}"
    exit 1
}

config_hash() {
    find "${WORKSPACE_DIR}/.devcontainer" -type f ! -name '.hash' -print0 \
        | xargs -0 shasum \
        | LC_ALL=C sort \
        | shasum \
        | awk '{print $1}'
}

container_id() {
    if [[ "${1:-all}" == "running" ]]; then
        docker ps -q --filter "label=${CONTAINER_LABEL}" | head -n1
        return 0
    fi

    docker ps -aq --filter "label=${CONTAINER_LABEL}" | head -n1
}

remove_container() {
    local ids

    ids="$(docker ps -aq --filter "label=${CONTAINER_LABEL}")"
    [[ -z "${ids}" ]] && return 0

    log "Removing existing devcontainer"
    printf '%s\n' "${ids}" | xargs -r docker rm -f >/dev/null
}

service_account_token() {
    if [[ -n "${SERVICE_ACCOUNT_TOKEN}" ]]; then
        log debug "Using service account token from --token"
        printf '%s\n' "${SERVICE_ACCOUNT_TOKEN}"
        return 0
    fi

    [[ -n "${VAULT}" ]] || return 1
    log debug "Reading OP_SERVICE_ACCOUNT_TOKEN from vault ${VAULT}"
    op read "op://${VAULT}/onepassword/OP_SERVICE_ACCOUNT_TOKEN"
}

prepare_container() {
    local force="${1:-false}"
    local command="${2:-run}"
    local current_hash cached_hash cid running_cid token

    mkdir -p "$(dirname "${HASH_FILE}")"
    current_hash="$(config_hash)"
    cached_hash="$(cat "${HASH_FILE}" 2>/dev/null || true)"
    cid="$(container_id)"
    running_cid="$(container_id running)"
    log debug "Container state current_hash=${current_hash} cached_hash=${cached_hash:-<empty>} cid=${cid:-<empty>} running_cid=${running_cid:-<empty>} force=${force} command=${command}"

    if [[ "${force}" == "true" || ( -n "${cid}" && -n "${cached_hash}" && "${current_hash}" != "${cached_hash}" ) ]]; then
        log debug "Container will be recreated"
        remove_container
        cid=
        running_cid=
    fi

    if [[ -z "${cid}" ]]; then
        log "Creating devcontainer"
        token="$(service_account_token)" || {
            case "${command}" in
                code)
                    log error "No devcontainer found. Re-run with --vault <vault> or --token <token> to create it first."
                    exit 1
                    ;;
                shell)
                    log error "No devcontainer found. Re-run with --vault <vault> or --token <token> to create it first."
                    exit 1
                    ;;
                *)
                    log error "Missing --vault <vault> or --token <token> to create the devcontainer."
                    exit 1
                    ;;
            esac
        }
        OP_SERVICE_ACCOUNT_TOKEN="${token}" log_preview devcontainer up || { log error "Failed to create devcontainer"; exit 1; }
        printf '%s\n' "${current_hash}" >"${HASH_FILE}"
        return 0
    fi

    if [[ -z "${running_cid}" ]]; then
        log "Starting existing devcontainer"
        log_preview devcontainer up || { log error "Failed to start existing devcontainer"; exit 1; }
    fi

    [[ "${current_hash}" == "${cached_hash}" ]] || printf '%s\n' "${current_hash}" >"${HASH_FILE}"
}

open_code() {
    log "Opening VS Code in devcontainer"
    code -n --folder-uri "${FOLDER_URI}"
}

open_shell() {
    local cid

    cid="$(container_id running)"
    [[ -n "${cid}" ]] || { log error "No running devcontainer found for ${WORKSPACE_DIR}"; exit 1; }
    clear

    exec docker exec -u "${CONTAINER_USER}" -w "${CONTAINER_DIR}" -it "${cid}" \
        "${CONTAINER_SHELL}" -lc 'clear; exec "$0" -il' "${CONTAINER_SHELL}"
}

run_flow() {
    local force="${1:-false}"
    local open_vscode="${2:-false}"
    local open_terminal="${3:-false}"
    local command="${4:-run}"

    log debug "run_flow force=${force} open_vscode=${open_vscode} open_terminal=${open_terminal} command=${command}"
    use_colima
    start_proxy
    prepare_container "${force}" "${command}"
    if [[ "${open_vscode}" == "true" ]]; then
        open_code
    fi
    if [[ "${open_terminal}" == "true" ]]; then
        open_shell
    fi
}

run_shell_flow() {
    local running_cid

    log debug "run_shell_flow workspace=${WORKSPACE_DIR}"
    check_dependencies shell
    use_colima
    running_cid="$(container_id running)"

    if [[ -n "${running_cid}" ]]; then
        log debug "Opening shell in already running devcontainer ${running_cid}"
        open_shell
        return 0
    fi

    require_workspace_config
    check_dependencies shell-bootstrap
    start_proxy
    prepare_container false shell
    open_shell
}

parse_args() {
    COMMAND=run

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --vault)
                shift
                [[ $# -gt 0 ]] || { log error "Missing value for --vault"; exit 1; }
                VAULT="$1"
                ;;
            --token)
                shift
                [[ $# -gt 0 ]] || { log error "Missing value for --token"; exit 1; }
                SERVICE_ACCOUNT_TOKEN="$1"
                ;;
            --user)
                shift
                [[ $# -gt 0 ]] || { log error "Missing value for --user"; exit 1; }
                CONTAINER_USER="$1"
                ;;
            --shell)
                shift
                [[ $# -gt 0 ]] || { log error "Missing value for --shell"; exit 1; }
                CONTAINER_SHELL="$1"
                ;;
            --workspace)
                shift
                [[ $# -gt 0 ]] || { log error "Missing value for --workspace"; exit 1; }
                WORKSPACE_DIR="$1"
                ;;
            --debug)
                LOG_LEVEL=debug
                ;;
            rebuild | code | shell)
                COMMAND="$1"
                ;;
            -h | --help | help)
                COMMAND=help
                return 0
                ;;
            *)
                usage
                log error "Unknown argument: $1"
                exit 1
                ;;
        esac
        shift
    done
}

check_dependencies() {
    local dep missing=()

    case "${1}" in
        run | code | rebuild)
            for dep in awk code devcontainer docker od shasum ssh tr xargs; do
                command -v "${dep}" >/dev/null 2>&1 || missing+=("${dep}")
            done
            [[ -n "${SERVICE_ACCOUNT_TOKEN}" ]] || {
                command -v op >/dev/null 2>&1 || missing+=("op")
            }
            ;;
        shell)
            for dep in docker od tr; do
                command -v "${dep}" >/dev/null 2>&1 || missing+=("${dep}")
            done
            ;;
        shell-bootstrap)
            for dep in awk devcontainer docker od shasum ssh tr xargs; do
                command -v "${dep}" >/dev/null 2>&1 || missing+=("${dep}")
            done
            [[ -n "${SERVICE_ACCOUNT_TOKEN}" ]] || {
                command -v op >/dev/null 2>&1 || missing+=("op")
            }
            ;;
    esac

    ((${#missing[@]} == 0)) || { log error "Missing required command(s): ${missing[*]}"; exit 1; }
}

main() {
    parse_args "$@"
    [[ "${COMMAND}" == "help" ]] && {
        usage
        return 0
    }
    set_workspace "${WORKSPACE_DIR}"
    log debug "Workspace=${WORKSPACE_DIR} command=${COMMAND} vault=${VAULT:-<empty>} user=${CONTAINER_USER} shell=${CONTAINER_SHELL} token_source=$([[ -n "${SERVICE_ACCOUNT_TOKEN}" ]] && printf 'flag' || printf 'vault')"

    case "${COMMAND}" in
        run)
            require_workspace_config
            check_dependencies run
            run_flow false true true run
            ;;
        code)
            require_workspace_config
            check_dependencies code
            run_flow false true false code
            ;;
        rebuild)
            require_workspace_config
            check_dependencies rebuild
            [[ -n "${VAULT}" || -n "${SERVICE_ACCOUNT_TOKEN}" ]] || { usage; log error "Missing --vault <vault> or --token <token> for rebuild."; exit 1; }
            run_flow true true true rebuild
            ;;
        shell)
            run_shell_flow
            ;;
        *)
            usage
            log error "Unknown command: ${COMMAND}"
            exit 1
            ;;
    esac
}

log_preview() {
    local log_file pid width line state move_up
    local shown=0
    local previous_state=
    local line_limit=10
    local color='\033[38;5;245m'
    local cursor_hidden=false

    preview_state() {
        tail -n "${line_limit}" "${log_file}" 2>/dev/null \
            | sed -E 's/^\[[0-9]{4}-[0-9]{2}-[0-9]{2}T[^]]+\][[:space:]]*//'
    }

    render_preview() {
        if (( shown > 0 )); then
            move_up="$(tput cuu "${shown}" 2>/dev/null || printf '\033[%sA' "${shown}")"
            printf '%s' "${move_up}"
        fi

        shown=0
        while IFS= read -r line; do
            ((shown++))
            printf '\033[2K'
            (( ${#line} >= width )) && line="${line:0:width-1}…"
            printf '%b%s\033[0m\n' "${color}" "${line}"
        done <<< "${1}"
    }

    finish_preview() {
        [[ "${cursor_hidden}" == "true" ]] && printf '\033[?25h'
        cursor_hidden=false
        [[ "${1:-keep}" == "delete" && -n "${log_file:-}" ]] && rm -f "${log_file}"
    }

    log_file="$(mktemp)"
    : >"${log_file}"

    "$@" >"${log_file}" 2>&1 &
    pid=$!

    trap '[[ -n "${pid:-}" ]] && kill "${pid}" >/dev/null 2>&1 || true; finish_preview delete; trap - INT TERM; exit 130' INT TERM
    printf '\033[?25l'
    cursor_hidden=true
    width="${COLUMNS:-$(tput cols 2>/dev/null || printf '120')}"
    (( width > 8 )) || width=120

    while kill -0 "${pid}" >/dev/null 2>&1; do
        state="$(preview_state)"
        if [[ -n "${state}" && "${state}" != "${previous_state}" ]]; then
            render_preview "${state}"
            previous_state="${state}"
        fi
        sleep 0.2
    done

    wait "${pid}" || {
        trap - INT TERM
        finish_preview
        cat "${log_file}" >&2
        rm -f "${log_file}"
        return 1
    }

    state="$(preview_state)"
    if [[ -n "${state}" && "${state}" != "${previous_state}" ]]; then
        render_preview "${state}"
    fi

    trap - INT TERM
    finish_preview delete
}

main "$@"
