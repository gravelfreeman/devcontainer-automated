{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "devcontainer-automated-template",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu@sha256:7ee7da33a68d997971660d91ecc8372e55a38a777c3c6bd6808daf91928052db",
  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/tmp/host.gitconfig,type=bind,consistency=cached,readonly",
    "source=/tmp/1password-ssh-agent.sock,target=/tmp/ssh-agent.sock,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/tmp/host-ssh,type=bind,consistency=cached,readonly"
  ],
  "containerEnv": {
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock"
  },
  "onCreateCommand": "bash ${containerWorkspaceFolder}/.devcontainer/onCreateCommand.sh ${containerWorkspaceFolder}",
  "userEnvProbe": "loginInteractiveShell",
  "updateRemoteUserUID": false,
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.hideOnStartup": "always"
      }
    }
  }
}